# ─────────────────────────────────────────────────────────────
# Delivery Slot Optimizer — Environment Configuration
# Copy to .env and customise before running docker-compose up
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
DB_NAME=delivery_optimizer
DB_USER=postgres
DB_PASS=postgres
DB_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379

# ── Spring Boot App ─────────────────────────────────────────
APP_PORT=8080
SERVER_PORT=8080

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Slot config ─────────────────────────────────────────────
# Capacity per slot window per zone (default: 20)
SLOT_CAPACITY=20
